{
  "name": "ai-powered-e-commerce-testing-framework",
  "version": "1.0.0",
  "scripts": {
    "test": "npm run test:bdd",
    "test:bdd": "cucumber-js bdd/features/**/*.feature --require-module ts-node/register --require bdd/steps/**/*.ts --require bdd/hooks/**/*.ts --format allure-cucumberjs/reporter",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:qa": "cross-env ENV=qa npm run test:bdd",
    "test:uat": "cross-env ENV=uat npm run test:bdd",
    "test:prod": "cross-env ENV=prod npm run test:bdd"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "allure-commandline": "^2.34.1",
    "allure-cucumberjs": "^3.10.2",
    "allure-js-commons": "^3.10.2",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "openai": "^6.45.0",
    "winston": "^3.19.0"
  }
}
